# ============================================================
#  .env.example  –  Template biến môi trường cho production
#  Sao chép thành .env (không commit .env lên git) hoặc
#  đặt trực tiếp vào CI/CD secret manager.
# ============================================================

# ── Server ────────────────────────────────────────────────
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=prod

# ── Database ──────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/motorbike_shop?useSSL=true
DB_USERNAME=your_db_user
DB_PASSWORD=your_strong_db_password

# ── JPA ───────────────────────────────────────────────────
# Dùng "validate" hay "none" trên production; "update" chỉ dùng khi dev
JPA_DDL_AUTO=validate

# ── Spring Security (basic auth) ──────────────────────────
SECURITY_USER_NAME=your_admin_username
SECURITY_USER_PASSWORD=your_strong_admin_password

# ── Mail (Gmail SMTP App Password) ────────────────────────
MAIL_USERNAME=your_gmail_account@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16_chars

# ── JWT ───────────────────────────────────────────────────
# Tạo secret mới bằng: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_BASE64_SECRET
JWT_EXPIRATION_MS=7200000

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL_SECURITY=WARN
